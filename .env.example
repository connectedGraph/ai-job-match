# job_system 环境变量模板
#
# 使用方法：
# 1. 将此文件复制为仓库根目录下的 `.env`。
# 2. 仅填写你运行的任务流所需的配置项。
# 3. 切勿提交真实的 API 密钥到代码库。
#
# 配置加载规则：
# - job-admin 后端读取仓库根目录的 `.env`。
# - career-planner 后端先读取仓库根目录的 `.env`，如果存在 `career-planner/.env` 则会接着读取。


# ---------------------------------------------------------------------------
# 本地端口与启动配置
# ---------------------------------------------------------------------------

# 可选。供 `python .\start_all.py` 脚本使用。
CAREER_FRONTEND_PORT=3000
CAREER_API_PORT=8001
JOB_ADMIN_API_PORT=8000
JOB_ADMIN_FRONTEND_PORT=5173
CAREER_API_TARGET=http://127.0.0.1:8001
JOB_ADMIN_API_TARGET=http://127.0.0.1:8000

# 可选。通常由 `start_all.py` 自动为学生端后端设置。
CAREER_PLANNER_API_ONLY=true

# 可选。Career Planner Vite 前端覆盖。使用开发代理（dev proxy）时请保持为空。
VITE_API_BASE_URL=
VITE_API_TARGET=http://127.0.0.1:8001

# 可选。覆盖共享职位库（job library）的路径。
JOB_SYSTEM_JOB_LIBRARY_PATH=


# ---------------------------------------------------------------------------
# Career Planner 身份验证 (Auth)
# ---------------------------------------------------------------------------

# 学生端后端必需。实际生产环境请使用长随机字符串。
CAREER_PLANNER_JWT_SECRET=replace-with-a-long-random-secret
CAREER_PLANNER_JWT_EXPIRE_MINUTES=10080


# ---------------------------------------------------------------------------
# Career Planner AI 大模型 (LLM)
# ---------------------------------------------------------------------------

# 用于学生端的 AI 评估、档案完整度检查、技能核验、能级推断、软素质和成长潜力分析。
# Job Admin 也会复用此兼容 OpenAI 的模型用于领域中心（Domain Center）的英译中显示名翻译。
# 推荐配置：
#   BASE_URL=
#   MODEL=gemini-3-flash-preview
#   TEMPERATURE=0.2
# OpenAI 兼容的聊天补全（chat completions）接口地址。
CAREER_PLANNER_AI_LLM_BASE_URL=
CAREER_PLANNER_AI_LLM_API_KEY=
CAREER_PLANNER_AI_LLM_MODEL=gemini-3-flash-preview
CAREER_PLANNER_AI_LLM_TEMPERATURE=0.2
CAREER_PLANNER_AI_LLM_MAX_TOKENS=4000
CAREER_PLANNER_AI_LLM_TIMEOUT_SECONDS=120


# ---------------------------------------------------------------------------
# Career Planner 简历解析大模型
# ---------------------------------------------------------------------------

# 用于接口 `/api/ai/resume/parse`。
# OpenAI 兼容的聊天补全接口。
CAREER_PLANNER_RESUME_LLM_BASE_URL=
CAREER_PLANNER_RESUME_LLM_API_KEY=
CAREER_PLANNER_RESUME_LLM_MODEL=
CAREER_PLANNER_RESUME_LLM_TEMPERATURE=0.1
CAREER_PLANNER_RESUME_LLM_MAX_TOKENS=4000
CAREER_PLANNER_RESUME_LLM_TIMEOUT_SECONDS=90


# ---------------------------------------------------------------------------
# Career Planner 专业技能搜索向量化 (Embedding)
# ---------------------------------------------------------------------------

# 仅用于：
#   GET /api/student-profile/professional-skills/search
#
# 用于“我的画像 / 专业技能构建”中的中文语义搜索。
# 它不参与后端归一化或最终的职位匹配。
# OpenAI 兼容的向量化接口：{BASE_URL}/embeddings。
#
# 如果 BASE_URL/API_KEY/MODEL 留空，默认会复用 JOB_SYSTEM_VECTOR_* 的配置
# 以及 dataset/db/tag_center 的向量缓存/索引。搜索仅对查询语句进行向量化；
# 候选向量从 skill_search_index_*_v2.json/.npy 中读取。
# 设置 CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_USE_JOB_SYSTEM_VECTOR=0 
# 可禁用上述回退机制，并在这些项为空时使用纯文本词法搜索。
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_BASE_URL=
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_API_KEY=
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_MODEL=
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_DIMENSIONS=
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_BATCH_SIZE=64
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_TIMEOUT_SECONDS=30
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_CACHE_FILE=
CAREER_PLANNER_SKILL_SEARCH_EMBEDDING_USE_JOB_SYSTEM_VECTOR=1


# ---------------------------------------------------------------------------
# Job Admin 通用文本大模型
# ---------------------------------------------------------------------------

# Job-admin 文本工作流使用的通用 OpenAI 兼容模型配置，
# 同时也作为匹配报告（match-report）生成的备用配置。
JOB_SYSTEM_TEXT_BASE_URL=
JOB_SYSTEM_TEXT_API_KEY=
JOB_SYSTEM_TEXT_MODEL=
JOB_SYSTEM_TEXT_TEMPERATURE=0.3
JOB_SYSTEM_TEXT_MAX_TOKENS=4000
JOB_SYSTEM_TEXT_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_TEXT_MAX_CONCURRENCY=30


# ---------------------------------------------------------------------------
# Job Admin 匹配报告大模型
# ---------------------------------------------------------------------------

# 仅用于在确定性匹配分数计算完成后生成自然语言报告。
# 它不参与分数或档位的决策。
# 如果 API key 为空，将回退到 JOB_SYSTEM_TEXT_API_KEY。
JOB_SYSTEM_MATCH_LLM_BASE_URL=
JOB_SYSTEM_MATCH_LLM_API_KEY=
JOB_SYSTEM_MATCH_LLM_MODEL=
JOB_SYSTEM_MATCH_LLM_TEMPERATURE=0.3
JOB_SYSTEM_MATCH_LLM_MAX_TOKENS=900
JOB_SYSTEM_MATCH_LLM_TIMEOUT_SECONDS=8


# ---------------------------------------------------------------------------
# Job Admin 匹配校验大模型 (Match Check)
# ---------------------------------------------------------------------------

# 可选。用于严格的预采集准入检查。如果为空，
# 将回退到通用文本大模型（JOB_SYSTEM_TEXT）的配置。
JOB_SYSTEM_MATCH_CHECK_LLM_BASE_URL=
JOB_SYSTEM_MATCH_CHECK_LLM_API_KEY=
JOB_SYSTEM_MATCH_CHECK_LLM_MODEL=gpt-5.4-mini
JOB_SYSTEM_MATCH_CHECK_LLM_TEMPERATURE=0
JOB_SYSTEM_MATCH_CHECK_LLM_MAX_TOKENS=1800
JOB_SYSTEM_MATCH_CHECK_LLM_TIMEOUT_SECONDS=18


# ---------------------------------------------------------------------------
# Job Admin 匹配 / 归一化向量化 (Embedding)
# ---------------------------------------------------------------------------

# 用于后端数据归一化和最终职位匹配的主要向量化配置。
# 当前支持的配置 ID 包括：
# - bigmodel_embedding_3 (智谱)
# - openrouter_gemini_embedding
# - gemini_embedding
# - legacy/default (传统/默认向量配置)
JOB_SYSTEM_VECTOR_PROFILE=bigmodel_embedding_3

# 智谱 BigModel embedding-3 配置。
JOB_SYSTEM_BIGMODEL_VECTOR_BASE_URL=https://open.bigmodel.cn/api/paas/v4
JOB_SYSTEM_BIGMODEL_VECTOR_API_KEY=
JOB_SYSTEM_BIGMODEL_VECTOR_MODEL=embedding-3
JOB_SYSTEM_BIGMODEL_VECTOR_DIMENSIONS=2048
JOB_SYSTEM_BIGMODEL_VECTOR_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_BIGMODEL_VECTOR_MAX_CONCURRENCY=30
JOB_SYSTEM_BIGMODEL_VECTOR_BATCH_SIZE=60

# 通用 OpenAI 兼容向量化回退配置。
JOB_SYSTEM_VECTOR_BASE_URL=
JOB_SYSTEM_VECTOR_API_KEY=
JOB_SYSTEM_VECTOR_MODEL=
JOB_SYSTEM_VECTOR_DIMENSIONS=
JOB_SYSTEM_VECTOR_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_VECTOR_MAX_CONCURRENCY=30
JOB_SYSTEM_VECTOR_BATCH_SIZE=60

# 可选：OpenRouter Gemini 向量化配置。
JOB_SYSTEM_OPENROUTER_API_KEY=

# 可选：直接调用 Gemini 向量化配置。
JOB_SYSTEM_GEMINI_VECTOR_API_KEY=


# ---------------------------------------------------------------------------
# Job Admin 归一化 / 标签中心翻译大模型
# ---------------------------------------------------------------------------

# 用于后端标签（Tag）归一化以及标签中心自动补充中文名称。
# OpenAI 兼容的聊天补全接口。
# 领域中心（Domain Center）翻译会优先使用上方的 CAREER_PLANNER_AI_LLM_* 配置，
# 仅当该配置的 Key 为空时才会回退到本组配置。
# 对于标签中心的纯翻译任务，gpt-5.4-mini 通常足够了。
JOB_SYSTEM_NORMALIZATION_LLM_BASE_URL=
JOB_SYSTEM_NORMALIZATION_LLM_API_KEY=
JOB_SYSTEM_NORMALIZATION_LLM_MODEL=
JOB_SYSTEM_NORMALIZATION_LLM_CACHE_FILE=normalized_cluster_llm_cache_v2.json
JOB_SYSTEM_NORMALIZATION_LLM_TEMPERATURE=0
JOB_SYSTEM_NORMALIZATION_LLM_MAX_TOKENS=4096
JOB_SYSTEM_NORMALIZATION_LLM_TIMEOUT_SECONDS=180
JOB_SYSTEM_NORMALIZATION_LLM_RPM=800
JOB_SYSTEM_NORMALIZATION_LLM_MAX_WORKERS=30

# 设置为 0/false/no 可禁用标签中心（Tag Center）自动中文翻译。
JOB_SYSTEM_TAG_TRANSLATION_ENABLED=1

# 设置为 0/false/no 可禁用领域中心（Domain Center）自动中文翻译。
JOB_SYSTEM_DOMAIN_TRANSLATION_ENABLED=1


# ---------------------------------------------------------------------------
# 调试配置 (Debugging)
# ---------------------------------------------------------------------------

# 仅在本地调试时设置为 true。可能会记录模型的原始输出日志。
CAREER_PLANNER_LOG_LLM_RAW_ON_PARSE_ERROR=false
CAREER_PLANNER_ENV=development
APP_ENV=development
ENV=development

# job_system 环境变量模板
#
# 使用方法：
# 1. 复制为仓库根目录 `.env`。
# 2. 只填写真实运行需要的 key，切勿提交真实密钥。
# 3. 聊天模型按 OpenAI-compatible `/v1/chat/completions` 协议调用；
#    向量模型按 OpenAI-compatible `{BASE_URL}/embeddings` 协议调用。


# ---------------------------------------------------------------------------
# 本地端口与启动配置
# ---------------------------------------------------------------------------

CAREER_FRONTEND_PORT=3000
CAREER_API_PORT=8001
JOB_ADMIN_API_PORT=8000
JOB_ADMIN_FRONTEND_PORT=5173
CAREER_API_TARGET=http://127.0.0.1:8001
JOB_ADMIN_API_TARGET=http://127.0.0.1:8000
CAREER_PLANNER_API_ONLY=true
VITE_API_BASE_URL=
VITE_API_TARGET=http://127.0.0.1:8001
JOB_SYSTEM_JOB_LIBRARY_PATH=


# ---------------------------------------------------------------------------
# Career Planner 身份验证
# ---------------------------------------------------------------------------

CAREER_PLANNER_JWT_SECRET=replace-with-a-long-random-secret
CAREER_PLANNER_JWT_EXPIRE_MINUTES=10080


# ---------------------------------------------------------------------------
# 旗舰模型：复杂推理 / 报告 / 结构化 JSON / 图片输入转回答
# ---------------------------------------------------------------------------
#
# 用途：
# - 学生端简历解析、画像 AI 评估、技能核验、能级推断、软素质和成长潜力分析
# - 岗位画像生成、深度匹配报告、JD 逐条解释、竞争力评估
# - 需要稳定 JSON 输出、长上下文或复杂推理的任务
#
# 推荐模型：
# - GPT-5.4
# - Claude Sonnet 4.5
# - DeepSeek V4 Pro
#
# 历史说明：
# 本项目早期开发时模型生态仍以 DeepSeek V3.2 等旧版能力为主要参照；
# 当前交付版建议优先使用上面的旗舰模型。

JOB_SYSTEM_FLAGSHIP_LLM_BASE_URL=
JOB_SYSTEM_FLAGSHIP_LLM_API_KEY=
JOB_SYSTEM_FLAGSHIP_LLM_MODEL=gpt-5.4
JOB_SYSTEM_FLAGSHIP_LLM_TEMPERATURE=0.3
JOB_SYSTEM_FLAGSHIP_LLM_MAX_TOKENS=4000
JOB_SYSTEM_FLAGSHIP_LLM_TIMEOUT_SECONDS=120
JOB_SYSTEM_FLAGSHIP_LLM_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_FLAGSHIP_LLM_MAX_CONCURRENCY=30


# ---------------------------------------------------------------------------
# 快速模型：简单分类 / 广告判定 / 轻量翻译 / 布尔判断
# ---------------------------------------------------------------------------
#
# 用途：
# - 简单分类、广告/异常判定、低风险复核
# - Tag Center / Domain Center 英文标准词到中文显示名的轻量翻译
# - 不需要旗舰模型深度推理的短任务
#
# 推荐模型：
# - GPT-5.4-mini
# - Claude Haiku 4.5
# - DeepSeek V4 Flash
#
# 可与旗舰模型使用完全不同的 BASE_URL / API_KEY / 供应商。

JOB_SYSTEM_FAST_LLM_BASE_URL=
JOB_SYSTEM_FAST_LLM_API_KEY=
JOB_SYSTEM_FAST_LLM_MODEL=gpt-5.4-mini
JOB_SYSTEM_FAST_LLM_TEMPERATURE=0
JOB_SYSTEM_FAST_LLM_MAX_TOKENS=2000
JOB_SYSTEM_FAST_LLM_TIMEOUT_SECONDS=60
JOB_SYSTEM_FAST_LLM_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_FAST_LLM_MAX_CONCURRENCY=30


# ---------------------------------------------------------------------------
# 向量模型：语义搜索 / 标签归一 / 匹配语义召回
# ---------------------------------------------------------------------------
#
# 用途：
# - 学生端“专业技能构建”中文语义搜索：将中文查询映射到英文标准标签
# - Tag Center 标签归一：相似标签聚类、标准词对齐、缓存补齐
# - 匹配链：语义召回、相似标签补齐、英文 normalizedTag 对齐
#
# 注意：
# - 向量模型不生成报告、不参与自然语言回答。
# - 最终分档和分数仍由确定性规则、英文 normalizedTag、能力等级和权重矩阵计算。
# - 默认示例使用智谱 BigModel embedding-3，维度为 2048。

JOB_SYSTEM_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
JOB_SYSTEM_EMBEDDING_API_KEY=
JOB_SYSTEM_EMBEDDING_MODEL=embedding-3
JOB_SYSTEM_EMBEDDING_DIMENSIONS=2048
JOB_SYSTEM_EMBEDDING_BATCH_SIZE=64
JOB_SYSTEM_EMBEDDING_TIMEOUT_SECONDS=180
JOB_SYSTEM_EMBEDDING_REQUESTS_PER_MINUTE=800
JOB_SYSTEM_EMBEDDING_MAX_CONCURRENCY=30


# ---------------------------------------------------------------------------
# 调试配置
# ---------------------------------------------------------------------------

CAREER_PLANNER_LOG_LLM_RAW_ON_PARSE_ERROR=false
CAREER_PLANNER_ENV=development
APP_ENV=development
ENV=development
